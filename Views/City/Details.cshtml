@model TasteTheWorld.Models.City
@{
    ViewData["Title"] = Model.Name;
}
<div class="city-detail-hero position-relative" style="background:@Model.BgColor; min-height:250px; overflow:hidden">
    @if (!string.IsNullOrEmpty(Model.ImageUrl))
    {
        <img src="@Model.ImageUrl" alt="@Model.Name"
             onerror="this.style.display='none'"
             style="position:absolute;inset:0;width:100%;height:100%;object-fit:cover;opacity:0.5" />
    }
    <div style="position:absolute;inset:0;background:linear-gradient(to top,rgba(0,0,0,0.75),rgba(0,0,0,0.2))"></div>
    <div class="container py-5 text-white text-center position-relative" style="z-index:2">
        <h1 class="fw-bold display-4">@Model.Name</h1>
        <p class="text-white-50 fs-5">@Model.CountryFlag @Model.Country · @Model.Foods.Count dishes</p>
    </div>
</div>
<div class="container py-5">
    <nav aria-label="breadcrumb" class="mb-4">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index" class="text-warning text-decoration-none">Home</a></li>
            <li class="breadcrumb-item"><a asp-action="Index" class="text-warning text-decoration-none">Cities</a></li>
            <li class="breadcrumb-item active">@Model.Name</li>
        </ol>
    </nav>
    <h3 class="mb-4"><i class="bi bi-fire text-warning"></i> Dishes from @Model.Name</h3>
    @if (!Model.Foods.Any())
    {
        <div class="alert alert-info">No dishes added for this city yet.</div>
    }
    <div class="row g-3">
        @foreach (var food in Model.Foods)
        {
            <div class="col-6 col-md-4 col-lg-3">
                <div class="food-card h-100">
                    <div class="food-card-img" style="padding:0;overflow:hidden">
                        @if (!string.IsNullOrEmpty(food.ImageUrl))
                        {
                            <img src="@food.ImageUrl" alt="@food.Name"
                                 onerror="this.style.display='none'; this.nextElementSibling.style.display='flex'"
                                 style="width:100%;height:120px;object-fit:cover;display:block" />
                            <span class="food-emoji" style="display:none">@food.Emoji</span>
                        }
                        else
                        {
                            <span class="food-emoji">@food.Emoji</span>
                        }
                        @if (food.IsSpicy) { <span class="badge bg-danger food-badge">🌶️</span> }
                        @if (food.IsVegetarian) { <span class="badge bg-success food-badge">🥗</span> }
                    </div>
                    <div class="food-card-body">
                        <span class="badge bg-secondary small mb-1">@food.Category</span>
                        <h6 class="food-name">@food.Name</h6>
                        <div class="d-flex justify-content-between align-items-center mb-2">
                            <span class="food-rating">★ @food.Rating <span class="text-muted small">(@food.ReviewCount)</span></span>
                            <span class="text-warning fw-bold">@food.PriceRange</span>
                        </div>
                        <a asp-controller="Food" asp-action="Details" asp-route-id="@food.Id" class="btn btn-outline-warning btn-sm w-100">Explore</a>
                    </div>
                </div>
            </div>
        }
    </div>
</div>

