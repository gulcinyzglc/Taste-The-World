@{
    ViewData["Title"] = "Home";
    var cities = ViewBag.Cities as List<TasteTheWorld.Models.City> ?? new();
    var foods = ViewBag.PopularFoods as List<TasteTheWorld.Models.Food> ?? new();
}

<section class="hero-section">
    <div class="hero-overlay"></div>
    <div class="container position-relative h-100" style="z-index:2">
        <div class="row justify-content-center text-center" style="min-height:480px;align-items:center;display:flex">
            <div class="col-lg-8 py-5">
                <span class="badge bg-warning text-dark mb-4 px-3 py-2 fs-6">
                    <i class="bi bi-fire"></i> @ViewBag.TotalFoods+ dishes · @ViewBag.TotalCities+ cities discovered
                </span>
                <h1 class="hero-title mb-3">Explore the World,<br>Taste the Best <span class="text-warning">Flavors!</span></h1>
                <p class="hero-subtitle mb-4">Visit every city and find its most iconic dish.<br>Discover world cuisines as you travel.</p>
                <form asp-controller="Food" asp-action="Index" method="get" class="hero-search-form mb-4">
                    <div class="input-group input-group-lg shadow" style="max-width:580px;margin:0 auto;border-radius:50px;overflow:hidden">
                        <span class="input-group-text bg-white border-0 ps-4"><i class="bi bi-search text-muted"></i></span>
                        <input type="text" name="search" class="form-control border-0 py-3" placeholder="Search food or city..." style="font-size:16px" />
                        <button class="btn btn-warning fw-bold px-4" type="submit" style="border-radius:0 50px 50px 0">Search</button>
                    </div>
                </form>
                <div class="d-flex gap-2 justify-content-center flex-wrap">
                    <a asp-controller="Food" asp-action="Index" class="btn btn-outline-light btn-sm rounded-pill px-3"><i class="bi bi-grid"></i> All Foods</a>
                    <a asp-controller="Food" asp-action="Index" asp-route-spicy="true" class="btn btn-outline-light btn-sm rounded-pill px-3">🌶️ Spicy</a>
                    <a asp-controller="Food" asp-action="Index" asp-route-vegetarian="true" class="btn btn-outline-light btn-sm rounded-pill px-3">🥗 Vegetarian</a>
                    <a asp-controller="City" asp-action="Index" class="btn btn-outline-light btn-sm rounded-pill px-3"><i class="bi bi-buildings"></i> Cities</a>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- STATS -->
<section class="py-4 bg-white border-bottom">
    <div class="container">
        <div class="row text-center g-3">
            <div class="col-6 col-md-3"><div class="stat-box"><div class="stat-num text-warning">@ViewBag.TotalFoods+</div><div class="stat-label">Food Recipes</div></div></div>
            <div class="col-6 col-md-3"><div class="stat-box"><div class="stat-num text-warning">@ViewBag.TotalCities+</div><div class="stat-label">Cities</div></div></div>
            <div class="col-6 col-md-3"><div class="stat-box"><div class="stat-num text-warning">142+</div><div class="stat-label">Countries</div></div></div>
            <div class="col-6 col-md-3"><div class="stat-box"><div class="stat-num text-warning">4.8</div><div class="stat-label">Avg. Rating</div></div></div>
        </div>
    </div>
</section>

<!-- CITIES -->
<section class="py-5">
    <div class="container">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h2 class="section-title"><i class="bi bi-buildings text-warning"></i> Popular Cities</h2>
            <a asp-controller="City" asp-action="Index" class="btn btn-outline-warning btn-sm">All Cities <i class="bi bi-arrow-right"></i></a>
        </div>
        <div class="row g-3">
            @foreach (var city in cities.Take(6))
            {
                <div class="col-6 col-md-4 col-lg-2">
                    <a asp-controller="City" asp-action="Details" asp-route-id="@city.Id" class="text-decoration-none">
                        <div class="city-card position-relative" style="background:@city.BgColor">
                            @if (!string.IsNullOrEmpty(city.ImageUrl))
                            {
                                <img src="@city.ImageUrl" alt="@city.Name"
                                     onerror="this.style.display='none'; this.nextElementSibling.style.display='block'"
                                     style="position:absolute;inset:0;width:100%;height:100%;object-fit:cover;opacity:0.55;border-radius:16px" />
                                <div class="city-emoji" style="display:none">@city.Emoji</div>
                            }
                            else
                            {
                                <div class="city-emoji">@city.Emoji</div>
                            }
                            <div class="city-overlay"></div>
                            <div class="city-info">
                                <div class="city-name">@city.Name</div>
                                <div class="city-country">@city.CountryFlag @city.Country</div>
                            </div>
                        </div>
                    </a>
                </div>
            }
        </div>
    </div>
</section>

<!-- POPULAR FOODS -->
<section class="py-5 bg-light">
    <div class="container">
        <div class="d-flex justify-content-between align-items-center mb-3">
            <h2 class="section-title"><i class="bi bi-fire text-warning"></i> Popular Dishes</h2>
            <a asp-controller="Food" asp-action="Index" class="btn btn-outline-warning btn-sm">All Dishes <i class="bi bi-arrow-right"></i></a>
        </div>
        <div class="btn-group mb-4 flex-wrap" role="group">
            <a asp-controller="Food" asp-action="Index" class="btn btn-warning btn-sm">All</a>
            <a asp-controller="Food" asp-action="Index" asp-route-category="Sokak Yemeği" class="btn btn-outline-secondary btn-sm">Street Food</a>
            <a asp-controller="Food" asp-action="Index" asp-route-category="Tatlı" class="btn btn-outline-secondary btn-sm">Dessert</a>
            <a asp-controller="Food" asp-action="Index" asp-route-category="Et Yemeği" class="btn btn-outline-secondary btn-sm">Meat</a>
            <a asp-controller="Food" asp-action="Index" asp-route-category="Deniz Ürünleri" class="btn btn-outline-secondary btn-sm">Seafood</a>
        </div>
        <div class="row g-3">
            @foreach (var food in foods)
            {
                <div class="col-6 col-md-4 col-lg-2">
                    <div class="food-card h-100">
                        <div class="food-card-img" style="padding:0;overflow:hidden">
                            @if (!string.IsNullOrEmpty(food.ImageUrl))
                            {
                                <img src="@food.ImageUrl" alt="@food.Name"
                                     onerror="this.style.display='none';this.nextElementSibling.style.display='block'"
                                     style="width:100%;height:120px;object-fit:cover;display:block" />
                                <span class="food-emoji" style="display:none">@food.Emoji</span>
                            }
                            else
                            {
                                <span class="food-emoji">@food.Emoji</span>
                            }
                            @if (Context.Session.GetString("UserEmail") != null)
                            {
                                <form asp-controller="BucketList" asp-action="Toggle" method="post" class="heart-form">
                                    <input type="hidden" name="foodId" value="@food.Id" />
                                    <button type="submit" class="heart-btn"><i class="bi bi-heart"></i></button>
                                </form>
                            }
                            @if (food.IsSpicy) { <span class="badge bg-danger food-badge">🌶️</span> }
                            @if (food.IsVegetarian) { <span class="badge bg-success food-badge">🥗</span> }
                        </div>
                        <div class="food-card-body">
                            <div class="food-city small text-muted"><i class="bi bi-geo-alt"></i> @food.City?.Name, @food.City?.Country</div>
                            <h6 class="food-name">@food.Name</h6>
                            <div class="d-flex justify-content-between align-items-center">
                                <span class="food-rating">★ @food.Rating <span class="text-muted small">(@food.ReviewCount)</span></span>
                                <span class="text-warning fw-bold">@food.PriceRange</span>
                            </div>
                            <a asp-controller="Food" asp-action="Details" asp-route-id="@food.Id" class="btn btn-outline-warning btn-sm w-100 mt-2">Explore</a>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
</section>

<!-- FEATURES -->
<section class="py-5 bg-white">
    <div class="container">
        <div class="row g-4">
            <div class="col-6 col-md-3">
                <div class="feature-box text-center">
                    <div class="feature-icon" style="background:#fff3e0"><i class="bi bi-globe text-warning" style="font-size:24px"></i></div>
                    <h6 class="mt-3 mb-1">Explore the World</h6>
                    <p class="text-muted small">40+ dishes from 15 cities</p>
                </div>
            </div>
            <div class="col-6 col-md-3">
                <div class="feature-box text-center">
                    <div class="feature-icon" style="background:#fce4ec"><i class="bi bi-star text-danger" style="font-size:24px"></i></div>
                    <h6 class="mt-3 mb-1">Rate & Review</h6>
                    <p class="text-muted small">Share your experience</p>
                </div>
            </div>
            <div class="col-6 col-md-3">
                <div class="feature-box text-center">
                    <div class="feature-icon" style="background:#e8f5e9"><i class="bi bi-heart text-success" style="font-size:24px"></i></div>
                    <h6 class="mt-3 mb-1">Build Your List</h6>
                    <p class="text-muted small">Manage your bucket list</p>
                </div>
            </div>
            <div class="col-6 col-md-3">
                <div class="feature-box text-center">
                    <div class="feature-icon" style="background:#e3f2fd"><i class="bi bi-map text-primary" style="font-size:24px"></i></div>
                    <h6 class="mt-3 mb-1">Plan Your Trip</h6>
                    <p class="text-muted small">Find the best restaurants</p>
                </div>
            </div>
        </div>
    </div>
</section>



