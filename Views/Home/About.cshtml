@{
    ViewData["Title"] = "About";
}
<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-8 text-center mb-5">
            <div style="font-size:80px">🌍</div>
            <h1 class="fw-bold mt-3">About TasteTheWorld</h1>
            <p class="text-muted fs-5">The best way to discover world cuisines through travel</p>
        </div>
    </div>
    <div class="row g-4 mb-5">
        <div class="col-md-4">
            <div class="card border-0 shadow-sm h-100 text-center p-4">
                <div style="font-size:48px">🎯</div>
                <h5 class="mt-3 fw-bold">Our Mission</h5>
                <p class="text-muted">To share the iconic dishes of every city with the world and make travel experiences richer.</p>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card border-0 shadow-sm h-100 text-center p-4">
                <div style="font-size:48px">🌟</div>
                <h5 class="mt-3 fw-bold">Our Vision</h5>
                <p class="text-muted">To build a global food community by bringing together flavors from every corner of the world.</p>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card border-0 shadow-sm h-100 text-center p-4">
                <div style="font-size:48px">💡</div>
                <h5 class="mt-3 fw-bold">Our Values</h5>
                <p class="text-muted">Authenticity, curiosity, and a passion for travel while respecting different cultures.</p>
            </div>
        </div>
    </div>

    <h3 class="mb-3 fw-bold"><i class="bi bi-question-circle text-warning"></i> FAQ</h3>
    <div class="accordion mb-5" id="faqAccordion">
        <div class="accordion-item border-0 shadow-sm mb-2">
            <h2 class="accordion-header">
                <button class="accordion-button fw-bold" type="button" data-bs-toggle="collapse" data-bs-target="#faq1">
                    What is TasteTheWorld?
                </button>
            </h2>
            <div id="faq1" class="accordion-collapse collapse show" data-bs-parent="#faqAccordion">
                <div class="accordion-body text-muted">
                    TasteTheWorld is a platform that lets you discover the most iconic dishes from cities around the world. You can add dishes to your lists, rate them, and leave reviews.
                </div>
            </div>
        </div>
        <div class="accordion-item border-0 shadow-sm mb-2">
            <h2 class="accordion-header">
                <button class="accordion-button collapsed fw-bold" type="button" data-bs-toggle="collapse" data-bs-target="#faq2">
                    How does the Bucket List work?
                </button>
            </h2>
            <div id="faq2" class="accordion-collapse collapse" data-bs-parent="#faqAccordion">
                <div class="accordion-body text-muted">
                    Click the heart icon on any food card to add it to your Bucket List. Once you've tried it, mark it with the "Tried it!" button.
                </div>
            </div>
        </div>
        <div class="accordion-item border-0 shadow-sm mb-2">
            <h2 class="accordion-header">
                <button class="accordion-button collapsed fw-bold" type="button" data-bs-toggle="collapse" data-bs-target="#faq3">
                    Can I add my own foods?
                </button>
            </h2>
            <div id="faq3" class="accordion-collapse collapse" data-bs-parent="#faqAccordion">
                <div class="accordion-body text-muted">
                    Yes! After logging in, click "Add Food" in the navbar dropdown. Enter the name, city, category, and description.
                </div>
            </div>
        </div>
    </div>
    <div class="text-center">
        <a asp-controller="Food" asp-action="Index" class="btn btn-warning btn-lg px-5 fw-bold">
            <i class="bi bi-compass"></i> Start Exploring
        </a>
    </div>
</div>
