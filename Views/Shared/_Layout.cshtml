<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - TasteTheWorld</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" />
    <link rel="stylesheet" href="~/css/site.css" />
</head>
<body>

@{
    var userName = Context.Session.GetString("UserName");
    var isLoggedIn = userName != null;
}

<nav class="navbar navbar-expand-lg ttw-navbar sticky-top">
    <div class="container">
        <a class="navbar-brand d-flex align-items-center gap-2" asp-controller="Home" asp-action="Index">
            <div class="brand-icon">🌍</div>
            <div>
                <div class="brand-name">TasteTheWorld</div>
                <div class="brand-sub">Eat as you travel!</div>
            </div>
        </a>
        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navMenu">
            <span class="navbar-toggler-icon"></span>
        </button>
        <div class="collapse navbar-collapse" id="navMenu">
            <ul class="navbar-nav mx-auto gap-1">
                <li class="nav-item">
                    <a class="nav-link" asp-controller="Home" asp-action="Index"><i class="bi bi-house"></i> Home</a>
                </li>
                <li class="nav-item dropdown">
                    <a class="nav-link dropdown-toggle" href="#" data-bs-toggle="dropdown"><i class="bi bi-compass"></i> Explore</a>
                    <ul class="dropdown-menu">
                        <li><a class="dropdown-item" asp-controller="Food" asp-action="Index">All Foods</a></li>
                        <li><hr class="dropdown-divider"></li>
                        <li><a class="dropdown-item" asp-controller="Food" asp-action="Index" asp-route-spicy="true">🌶️ Spicy Foods</a></li>
                        <li><a class="dropdown-item" asp-controller="Food" asp-action="Index" asp-route-vegetarian="true">🥗 Vegetarian</a></li>
                    </ul>
                </li>
                <li class="nav-item">
                    <a class="nav-link" asp-controller="City" asp-action="Index"><i class="bi bi-buildings"></i> Cities</a>
                </li>
                @if (isLoggedIn)
                {
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="BucketList" asp-action="Index"><i class="bi bi-heart"></i> My List</a>
                    </li>
                }
                <li class="nav-item">
                    <a class="nav-link" asp-controller="Home" asp-action="About"><i class="bi bi-info-circle"></i> About</a>
                </li>
            </ul>

            <div class="d-flex gap-2 align-items-center">
                @if (isLoggedIn)
                {
                    <div class="dropdown">
                        <button class="btn btn-outline-light btn-sm dropdown-toggle d-flex align-items-center gap-2" data-bs-toggle="dropdown">
                            <div class="user-avatar">@userName![0]</div>
                            @userName
                        </button>
                        <ul class="dropdown-menu dropdown-menu-end">
                            <li><h6 class="dropdown-header">Welcome back! 👋</h6></li>
                            <li><a class="dropdown-item" asp-controller="Food" asp-action="Create"><i class="bi bi-plus-circle me-2"></i>Add Food</a></li>
                            <li><a class="dropdown-item" asp-controller="BucketList" asp-action="Index"><i class="bi bi-heart me-2"></i>My List</a></li>
                            <li><hr class="dropdown-divider"></li>
                            <li>
                                <form asp-controller="Account" asp-action="Logout" method="post" class="d-inline">
                                    <button type="submit" class="dropdown-item text-danger">
                                        <i class="bi bi-box-arrow-right me-2"></i>Logout
                                    </button>
                                </form>
                            </li>
                        </ul>
                    </div>
                }
                else
                {
                    <a asp-controller="Account" asp-action="Login" class="btn btn-outline-light btn-sm">Login</a>
                    <a asp-controller="Account" asp-action="Register" class="btn btn-warning btn-sm fw-bold">Sign Up</a>
                }
            </div>
        </div>
    </div>
</nav>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show mb-0 rounded-0 text-center" role="alert">
        <i class="bi bi-check-circle"></i> @TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<main>@RenderBody()</main>

<footer class="ttw-footer mt-5">
    <div class="container">
        <div class="row py-4">
            <div class="col-md-4">
                <h5 class="text-white mb-2">🌍 TasteTheWorld</h5>
                <p class="text-white-50 small">Every city has a flavor. Explore world cuisines!</p>
            </div>
            <div class="col-md-4">
                <h6 class="text-white mb-2">Quick Links</h6>
                <ul class="list-unstyled small">
                    <li><a asp-controller="Food" asp-action="Index" class="text-white-50 text-decoration-none">Foods</a></li>
                    <li><a asp-controller="City" asp-action="Index" class="text-white-50 text-decoration-none">Cities</a></li>
                    <li><a asp-controller="BucketList" asp-action="Index" class="text-white-50 text-decoration-none">Bucket List</a></li>
                </ul>
            </div>
            <div class="col-md-4">
                <h6 class="text-white mb-2">Contact</h6>
                <p class="text-white-50 small">info@tastetheworld.com</p>
            </div>
        </div>
        <hr class="border-secondary" />
        <p class="text-center text-white-50 small py-2">© 2026 TasteTheWorld — Every bite tells a story 🍽️</p>
    </div>
</footer>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
<script src="~/js/site.js"></script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>

