@model List<TasteTheWorld.Models.BucketList>
@{
    ViewData["Title"] = "My List";
    var tried = Model.Where(b => b.IsTried).ToList();
    var wantTo = Model.Where(b => !b.IsTried).ToList();
}
<div class="container py-5">
    <h2 class="section-title mb-4"><i class="bi bi-heart-fill text-danger"></i> My Food Bucket List</h2>
    <div class="row g-3 mb-4">
        <div class="col-6 col-md-3">
            <div class="card border-0 shadow-sm text-center p-3">
                <div class="fs-2 fw-bold text-warning">@Model.Count</div>
                <div class="text-muted small">Total</div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="card border-0 shadow-sm text-center p-3">
                <div class="fs-2 fw-bold text-success">@tried.Count</div>
                <div class="text-muted small">Tried ✓</div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="card border-0 shadow-sm text-center p-3">
                <div class="fs-2 fw-bold text-warning">@wantTo.Count</div>
                <div class="text-muted small">Want to Try</div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="card border-0 shadow-sm text-center p-3">
                <div class="fs-2 fw-bold text-primary">
                    @(Model.Count > 0 ? (int)((double)tried.Count / Model.Count * 100) : 0)%
                </div>
                <div class="text-muted small">Completed</div>
            </div>
        </div>
    </div>

    @if (!Model.Any())
    {
        <div class="alert alert-light border text-center py-5">
            <div style="font-size:60px">🍽️</div>
            <h5 class="mt-3">Your list is empty!</h5>
            <p class="text-muted">Explore dishes and add them to your bucket list.</p>
            <a asp-controller="Food" asp-action="Index" class="btn btn-warning">Explore Dishes</a>
        </div>
    }
    else
    {
        <div class="mb-4">
            <button class="btn btn-outline-warning w-100 text-start fw-bold mb-2" data-bs-toggle="collapse" data-bs-target="#wantList">
                <i class="bi bi-clock-history"></i> Want to Try (@wantTo.Count)
                <i class="bi bi-chevron-down float-end"></i>
            </button>
            <div class="collapse show" id="wantList">
                <div class="card border-0 shadow-sm">
                    <div class="table-responsive">
                        <table class="table table-striped table-hover mb-0">
                            <thead class="table-warning">
                                <tr>
                                    <th>Food</th><th>City</th><th>Rating</th><th>Added</th><th>Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in wantTo)
                                {
                                    <tr>
                                        <td><span class="me-2">@item.Food?.Emoji</span><strong>@item.Food?.Name</strong></td>
                                        <td>@item.Food?.City?.CountryFlag @item.Food?.City?.Name</td>
                                        <td><span class="text-warning">★</span> @item.Food?.Rating</td>
                                        <td class="text-muted small">@item.AddedDate.ToString("dd MMM yyyy")</td>
                                        <td>
                                            <div class="d-flex gap-1">
                                                <form asp-action="MarkTried" method="post">
                                                    <input type="hidden" name="id" value="@item.Id" />
                                                    <button type="submit" class="btn btn-success btn-sm"><i class="bi bi-check-circle"></i> Tried it!</button>
                                                </form>
                                                <a asp-controller="Food" asp-action="Details" asp-route-id="@item.FoodId" class="btn btn-outline-warning btn-sm">View</a>
                                                <form asp-controller="BucketList" asp-action="Toggle" method="post">
                                                    <input type="hidden" name="foodId" value="@item.FoodId" />
                                                    <button type="submit" class="btn btn-outline-danger btn-sm"><i class="bi bi-trash"></i></button>
                                                </form>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>

        <div class="mb-4">
            <button class="btn btn-outline-success w-100 text-start fw-bold mb-2" data-bs-toggle="collapse" data-bs-target="#triedList">
                <i class="bi bi-check-circle"></i> Already Tried (@tried.Count)
                <i class="bi bi-chevron-down float-end"></i>
            </button>
            <div class="collapse show" id="triedList">
                <div class="card border-0 shadow-sm">
                    <div class="table-responsive">
                        <table class="table table-striped table-hover mb-0">
                            <thead class="table-success">
                                <tr><th>Food</th><th>City</th><th>Rating</th><th>Actions</th></tr>
                            </thead>
                            <tbody>
                                @foreach (var item in tried)
                                {
                                    <tr>
                                        <td><span class="me-2">@item.Food?.Emoji</span><strong>@item.Food?.Name</strong></td>
                                        <td>@item.Food?.City?.CountryFlag @item.Food?.City?.Name</td>
                                        <td><span class="text-warning">★</span> @item.Food?.Rating</td>
                                        <td>
                                            <div class="d-flex gap-1">
                                                <a asp-controller="Food" asp-action="Details" asp-route-id="@item.FoodId" class="btn btn-outline-warning btn-sm">View</a>
                                                <form asp-controller="BucketList" asp-action="Toggle" method="post">
                                                    <input type="hidden" name="foodId" value="@item.FoodId" />
                                                    <button type="submit" class="btn btn-outline-danger btn-sm"><i class="bi bi-trash"></i></button>
                                                </form>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>

        <nav>
            <ul class="pagination justify-content-center">
                <li class="page-item disabled"><a class="page-link">Previous</a></li>
                <li class="page-item active"><a class="page-link" href="#">1</a></li>
                <li class="page-item"><a class="page-link" href="#">2</a></li>
                <li class="page-item"><a class="page-link" href="#">Next</a></li>
            </ul>
        </nav>
    }
</div>
