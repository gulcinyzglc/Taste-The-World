@model TasteTheWorld.Models.Food
@{
    ViewData["Title"] = "Edit: " + Model.Name;
    var cities = ViewBag.Cities as List<TasteTheWorld.Models.City> ?? new();
}
<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-7">
            <div class="card border-0 shadow-sm">
                <div class="card-header bg-primary text-white fw-bold fs-5">
                    <i class="bi bi-pencil-square"></i> Edit Food: @Model.Name
                </div>
                <div class="card-body p-4">
                    <form asp-action="Edit" method="post">
                        <input type="hidden" asp-for="Id" />
                        <div class="mb-3">
                            <label asp-for="Name" class="form-label fw-bold">Food Name *</label>
                            <input asp-for="Name" class="form-control" required />
                        </div>
                        <div class="mb-3">
                            <label asp-for="Description" class="form-label fw-bold">Description</label>
                            <textarea asp-for="Description" class="form-control" rows="3"></textarea>
                        </div>
                        <div class="row g-3 mb-3">
                            <div class="col-md-6">
                                <label asp-for="Emoji" class="form-label fw-bold">Emoji</label>
                                <input asp-for="Emoji" class="form-control" />
                            </div>
                            <div class="col-md-12 mt-2">
                                <label asp-for="ImageUrl" class="form-label fw-bold">Image URL <span class="text-muted fw-normal">(optional)</span></label>
                                <input asp-for="ImageUrl" class="form-control" id="imageUrlInput" />
                                <div class="mt-2" id="imagePreview">
                                    @if (!string.IsNullOrEmpty(Model.ImageUrl))
                                    {
                                        <img id="previewImg" src="@Model.ImageUrl" alt="Preview" class="rounded" style="height:120px;object-fit:cover;border:1px solid #dee2e6" />
                                    }
                                    else
                                    {
                                        <img id="previewImg" src="" alt="Preview" class="rounded" style="height:120px;object-fit:cover;border:1px solid #dee2e6;display:none" />
                                    }
                                </div>
                            </div>
                            <div class="col-md-6">
                                <label asp-for="Category" class="form-label fw-bold">Category</label>
                                <select asp-for="Category" class="form-select">
                                    <option>Sokak Yemeği</option><option>Et Yemeği</option>
                                    <option>Deniz Ürünleri</option><option>Pizza</option>
                                    <option>Çorba</option><option>Tatlı</option>
                                    <option>Erişte</option><option>Pastane</option>
                                </select>
                            </div>
                        </div>
                        <div class="row g-3 mb-3">
                            <div class="col-md-6">
                                <label asp-for="CityId" class="form-label fw-bold">City</label>
                                <select asp-for="CityId" class="form-select">
                                    @foreach (var city in cities)
                                    {
                                        <option value="@city.Id">@city.CountryFlag @city.Name</option>
                                    }
                                </select>
                            </div>
                            <div class="col-md-6">
                                <label asp-for="PriceRange" class="form-label fw-bold">Price Range</label>
                                <select asp-for="PriceRange" class="form-select">
                                    <option value="₺">₺</option><option value="₺₺">₺₺</option>
                                    <option value="€€">€€</option><option value="€€€">€€€</option>
                                    <option value="€€€€">€€€€</option>
                                </select>
                            </div>
                        </div>
                        <div class="row g-3 mb-3">
                            <div class="col-md-6">
                                <label asp-for="Rating" class="form-label fw-bold">Rating</label>
                                <input asp-for="Rating" type="number" step="0.1" min="1" max="5" class="form-control" />
                            </div>
                            <div class="col-md-6">
                                <label asp-for="ReviewCount" class="form-label fw-bold">Review Count</label>
                                <input asp-for="ReviewCount" type="number" class="form-control" />
                            </div>
                        </div>
                        <div class="d-flex gap-4 mb-4">
                            <div class="form-check">
                                <input asp-for="IsSpicy" type="checkbox" class="form-check-input" />
                                <label asp-for="IsSpicy" class="form-check-label">🌶️ Spicy</label>
                            </div>
                            <div class="form-check">
                                <input asp-for="IsVegetarian" type="checkbox" class="form-check-input" />
                                <label asp-for="IsVegetarian" class="form-check-label">🥗 Vegetarian</label>
                            </div>
                        </div>
                        <div class="d-flex gap-2">
                            <button type="submit" class="btn btn-primary fw-bold flex-grow-1"><i class="bi bi-save"></i> Save Changes</button>
                            <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
document.getElementById('imageUrlInput').addEventListener('input', function() {
    var url = this.value.trim();
    var img = document.getElementById('previewImg');
    if (url) {
        img.src = url;
        img.style.display = 'block';
        img.onerror = function() { img.style.display = 'none'; };
    } else {
        img.style.display = 'none';
    }
});
</script>
}
