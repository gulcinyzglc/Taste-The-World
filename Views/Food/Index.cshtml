@model List<TasteTheWorld.Models.Food>
@{
    ViewData["Title"] = "Foods";
    var categories = ViewBag.Categories as List<string> ?? new();
}

<div class="container py-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="section-title"><i class="bi bi-fire text-warning"></i> All Dishes</h2>
        @if (Context.Session.GetString("UserEmail") != null)
        {
            <a asp-action="Create" class="btn btn-warning"><i class="bi bi-plus-circle"></i> Add Food</a>
        }
    </div>

    <form method="get" class="mb-4">
        <div class="row g-2">
            <div class="col-md-5">
                <div class="input-group">
                    <span class="input-group-text"><i class="bi bi-search"></i></span>
                    <input type="text" name="search" value="@ViewBag.Search" class="form-control" placeholder="Search food or city..." />
                </div>
            </div>
            <div class="col-md-3">
                <select name="category" class="form-select">
                    <option value="">All Categories</option>
                    @foreach (var cat in categories)
                    {
                        <option value="@cat" selected="@(ViewBag.Category == cat)">@cat</option>
                    }
                </select>
            </div>
            <div class="col-md-2">
                <div class="form-check mt-2">
                    <input type="checkbox" name="spicy" value="true" class="form-check-input" id="spicy" />
                    <label class="form-check-label" for="spicy">🌶️ Spicy only</label>
                </div>
            </div>
            <div class="col-md-2">
                <button type="submit" class="btn btn-warning w-100">Filter</button>
            </div>
        </div>
    </form>

    <div class="btn-group mb-4 flex-wrap" role="group">
        <a asp-action="Index" class="btn btn-sm @(ViewBag.Category == null ? "btn-warning" : "btn-outline-secondary")">All</a>
        @foreach (var cat in categories)
        {
            <a asp-action="Index" asp-route-category="@cat" class="btn btn-sm @(ViewBag.Category == cat ? "btn-warning" : "btn-outline-secondary")">@cat</a>
        }
    </div>

    @if (!Model.Any())
    {
        <div class="alert alert-info"><i class="bi bi-info-circle"></i> No results found.</div>
    }

    <div class="row g-3 mb-4">
        @foreach (var food in Model)
        {
            <div class="col-6 col-md-4 col-lg-3">
                <div class="food-card h-100">
                    <div class="food-card-img" style="padding:0;overflow:hidden">
                        @if (!string.IsNullOrEmpty(food.ImageUrl))
                        {
                            <img src="@food.ImageUrl" alt="@food.Name"
                                 onerror="this.style.display='none';this.nextElementSibling.style.display='block'"
                                 style="width:100%;height:120px;object-fit:cover;display:block" />
                            <span class="food-emoji" style="display:none">@food.Emoji</span>
                        }
                        else
                        {
                            <span class="food-emoji">@food.Emoji</span>
                        }
                        @if (Context.Session.GetString("UserEmail") != null)
                        {
                            <form asp-controller="BucketList" asp-action="Toggle" method="post" class="heart-form">
                                <input type="hidden" name="foodId" value="@food.Id" />
                                <button type="submit" class="heart-btn"><i class="bi bi-heart"></i></button>
                            </form>
                        }
                        @if (food.IsSpicy) { <span class="badge bg-danger food-badge">🌶️</span> }
                        @if (food.IsVegetarian) { <span class="badge bg-success food-badge">🥗</span> }
                    </div>
                    <div class="food-card-body">
                        <div class="food-city small text-muted"><i class="bi bi-geo-alt"></i> @food.City?.Name, @food.City?.Country</div>
                        <h6 class="food-name">@food.Name</h6>
                        <p class="text-muted small mb-2" style="overflow:hidden;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical">@food.Description</p>
                        <div class="d-flex justify-content-between align-items-center mb-2">
                            <span class="food-rating">★ @food.Rating <span class="text-muted small">(@food.ReviewCount)</span></span>
                            <span class="text-warning fw-bold">@food.PriceRange</span>
                        </div>
                        <div class="d-flex gap-1">
                            <a asp-action="Details" asp-route-id="@food.Id" class="btn btn-outline-warning btn-sm flex-grow-1">Explore</a>
                            @if (Context.Session.GetString("UserEmail") != null)
                            {
                                <a asp-action="Edit" asp-route-id="@food.Id" class="btn btn-outline-secondary btn-sm"><i class="bi bi-pencil"></i></a>
                                <form asp-action="Delete" method="post" onsubmit="return confirm('Are you sure you want to delete this?')">
                                    <input type="hidden" name="id" value="@food.Id" />
                                    <button type="submit" class="btn btn-outline-danger btn-sm"><i class="bi bi-trash"></i></button>
                                </form>
                            }
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>

    <!-- Table -->
    <div class="card border-0 shadow-sm">
        <div class="card-header bg-warning text-dark fw-bold">
            <i class="bi bi-table"></i> Table View
        </div>
        <div class="table-responsive">
            <table class="table table-striped table-hover mb-0">
                <thead class="table-dark">
                    <tr>
                        <th>#</th>
                        <th>Food</th>
                        <th>City</th>
                        <th>Category</th>
                        <th>Rating</th>
                        <th>Price</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var food in Model)
                    {
                        <tr>
                            <td>@food.Id</td>
                            <td><span class="me-1">@food.Emoji</span> @food.Name</td>
                            <td>@food.City?.Name @food.City?.CountryFlag</td>
                            <td><span class="badge bg-secondary">@food.Category</span></td>
                            <td><span class="text-warning">★</span> @food.Rating</td>
                            <td class="text-warning fw-bold">@food.PriceRange</td>
                            <td>
                                <div class="btn-group btn-group-sm">
                                    <a asp-action="Details" asp-route-id="@food.Id" class="btn btn-success">View</a>
                                    @if (Context.Session.GetString("UserEmail") != null)
                                    {
                                        <a asp-action="Edit" asp-route-id="@food.Id" class="btn btn-primary">Edit</a>
                                        <form asp-action="Delete" method="post" onsubmit="return confirm('Are you sure?')" class="d-inline">
                                            <input type="hidden" name="id" value="@food.Id" />
                                            <button type="submit" class="btn btn-danger">Delete</button>
                                        </form>
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    <nav class="mt-4">
        <ul class="pagination justify-content-center">
            <li class="page-item disabled"><a class="page-link">Previous</a></li>
            <li class="page-item active"><a class="page-link" href="#">1</a></li>
            <li class="page-item"><a class="page-link" href="#">2</a></li>
            <li class="page-item"><a class="page-link" href="#">3</a></li>
            <li class="page-item"><a class="page-link" href="#">Next</a></li>
        </ul>
    </nav>
</div>


