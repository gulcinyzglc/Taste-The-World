@model TasteTheWorld.Models.Food
@{
    ViewData["Title"] = Model.Name;
    var related = ViewBag.RelatedFoods as List<TasteTheWorld.Models.Food> ?? new();
}

<div class="container py-5">
    <nav aria-label="breadcrumb" class="mb-4">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index" class="text-warning text-decoration-none">Home</a></li>
            <li class="breadcrumb-item"><a asp-controller="Food" asp-action="Index" class="text-warning text-decoration-none">Foods</a></li>
            <li class="breadcrumb-item active">@Model.Name</li>
        </ol>
    </nav>

    <div class="row g-4">
        <div class="col-lg-5">
            <div class="food-detail-img rounded-4 shadow" style="height:320px;background:linear-gradient(135deg,#fff3e0,#ffe0b2);overflow:hidden;position:relative">
                @if (!string.IsNullOrEmpty(Model.ImageUrl))
                {
                    <img src="@Model.ImageUrl" alt="@Model.Name"
                         onerror="this.style.display='none';this.nextElementSibling.style.display='flex'"
                         style="width:100%;height:100%;object-fit:cover" />
                    <div style="display:none;align-items:center;justify-content:center;height:100%;font-size:120px">@Model.Emoji</div>
                }
                else
                {
                    <div style="display:flex;align-items:center;justify-content:center;height:100%;font-size:120px">@Model.Emoji</div>
                }
            </div>
        </div>
        <div class="col-lg-7">
            <div class="d-flex gap-2 mb-2 flex-wrap">
                <span class="badge bg-warning text-dark">@Model.Category</span>
                @if (Model.IsSpicy) { <span class="badge bg-danger">🌶️ Spicy</span> }
                @if (Model.IsVegetarian) { <span class="badge bg-success">🥗 Vegetarian</span> }
            </div>
            <h1 class="fw-bold mb-1">@Model.Name</h1>
            <p class="text-muted mb-3"><i class="bi bi-geo-alt text-warning"></i> @Model.City?.Name, @Model.City?.Country @Model.City?.CountryFlag</p>
            <div class="d-flex align-items-center gap-3 mb-3">
                <div class="d-flex align-items-center gap-1">
                    @for (int i = 1; i <= 5; i++)
                    {
                        <i class="bi bi-star-fill @(i <= (int)Model.Rating ? "text-warning" : "text-muted")"></i>
                    }
                    <span class="fw-bold ms-1">@Model.Rating</span>
                    <span class="text-muted small">(@Model.ReviewCount reviews)</span>
                </div>
                <span class="fs-5 fw-bold text-warning">@Model.PriceRange</span>
            </div>
            <p class="text-muted">@Model.Description</p>

            <div class="d-flex gap-2 mt-4 flex-wrap">
                @if (Context.Session.GetString("UserEmail") != null)
                {
                    <form asp-controller="BucketList" asp-action="Toggle" method="post">
                        <input type="hidden" name="foodId" value="@Model.Id" />
                        <button type="submit" class="btn btn-outline-danger"><i class="bi bi-heart"></i> Add to List</button>
                    </form>
                }
                else
                {
                    <a asp-controller="Account" asp-action="Login" class="btn btn-outline-danger">
                        <i class="bi bi-heart"></i> Add to List
                    </a>
                }
                <a asp-controller="City" asp-action="Details" asp-route-id="@Model.CityId" class="btn btn-outline-warning">
                    <i class="bi bi-buildings"></i> Explore @Model.City?.Name
                </a>
                @if (Context.Session.GetString("UserEmail") != null)
                {
                    <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-outline-secondary"><i class="bi bi-pencil"></i> Edit</a>
                }
            </div>
        </div>
    </div>

    <div class="row mt-5 g-4">
        <div class="col-lg-7">
            <h4 class="mb-4"><i class="bi bi-chat-square-text text-warning"></i> Reviews (@Model.Reviews.Count)</h4>
            @if (!Model.Reviews.Any())
            {
                <div class="alert alert-light border">No reviews yet. Be the first to review!</div>
            }
            @foreach (var review in Model.Reviews.OrderByDescending(r => r.CreatedAt))
            {
                <div class="review-card mb-3">
                    <div class="d-flex justify-content-between align-items-start">
                        <div>
                            <span class="fw-bold">@review.AuthorName</span>
                            <span class="text-muted small ms-2">@review.CreatedAt.ToString("dd MMM yyyy")</span>
                        </div>
                        <div>
                            @for (int i = 1; i <= 5; i++)
                            {
                                <i class="bi bi-star-fill @(i <= review.Stars ? "text-warning" : "text-muted")" style="font-size:12px"></i>
                            }
                        </div>
                    </div>
                    <p class="mt-2 mb-0 text-muted">@review.Comment</p>
                </div>
            }

            @if (Context.Session.GetString("UserEmail") != null)
            {
                <div class="card border-0 shadow-sm mt-4">
                    <div class="card-header bg-warning text-dark fw-bold"><i class="bi bi-plus-circle"></i> Add a Review</div>
                    <div class="card-body">
                        <form asp-action="AddReview" method="post">
                            <input type="hidden" name="foodId" value="@Model.Id" />
                            <div class="mb-3">
                                <label class="form-label fw-bold">Your Name</label>
                                <input type="text" name="authorName" class="form-control" required placeholder="Enter your name..." />
                            </div>
                            <div class="mb-3">
                                <label class="form-label fw-bold">Rating</label>
                                <select name="stars" class="form-select" required>
                                    <option value="5">⭐⭐⭐⭐⭐ Excellent</option>
                                    <option value="4">⭐⭐⭐⭐ Very Good</option>
                                    <option value="3">⭐⭐⭐ Good</option>
                                    <option value="2">⭐⭐ Average</option>
                                    <option value="1">⭐ Poor</option>
                                </select>
                            </div>
                            <div class="mb-3">
                                <label class="form-label fw-bold">Your Review</label>
                                <textarea name="comment" class="form-control" rows="3" required placeholder="Share your experience..."></textarea>
                            </div>
                            <button type="submit" class="btn btn-warning fw-bold w-100">Submit Review</button>
                        </form>
                    </div>
                </div>
            }
            else
            {
                <div class="card border-0 shadow-sm mt-4 text-center p-4">
                    <i class="bi bi-lock text-warning" style="font-size:32px"></i>
                    <p class="mt-2 mb-3 text-muted">You need to be logged in to write a review.</p>
                    <a asp-controller="Account" asp-action="Login" class="btn btn-warning fw-bold px-4">
                        <i class="bi bi-box-arrow-in-right"></i> Login
                    </a>
                </div>
            }
        </div>

        <div class="col-lg-5">
            <h5 class="mb-3"><i class="bi bi-grid text-warning"></i> More from @Model.City?.Name</h5>
            @foreach (var r in related)
            {
                <div class="d-flex gap-3 mb-3 p-3 border rounded-3 related-card">
                    <div style="width:56px;height:56px;border-radius:10px;overflow:hidden;flex-shrink:0;background:linear-gradient(135deg,#fff3e0,#ffe0b2);display:flex;align-items:center;justify-content:center;font-size:28px">
                        @if (!string.IsNullOrEmpty(r.ImageUrl))
                        {
                            <img src="@r.ImageUrl" alt="@r.Name"
                                 onerror="this.style.display='none';this.nextElementSibling.style.display='block'"
                                 style="width:100%;height:100%;object-fit:cover" />
                            <span style="display:none">@r.Emoji</span>
                        }
                        else
                        {
                            <span>@r.Emoji</span>
                        }
                    </div>
                    <div class="flex-grow-1">
                        <div class="fw-bold small">@r.Name</div>
                        <div class="text-muted" style="font-size:11px">★ @r.Rating · @r.PriceRange</div>
                    </div>
                    <a asp-action="Details" asp-route-id="@r.Id" class="btn btn-outline-warning btn-sm align-self-center">View</a>
                </div>
            }
        </div>
    </div>
</div>

